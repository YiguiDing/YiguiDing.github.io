
<link  href="<%- theme.cdn.fancybox.css %>" rel="stylesheet">
<script src="<%- theme.cdn.fancybox.js %>"></script>

<!-- highlight.js代码高亮css -->
<link href="<%- theme.cdn.highlight.css %>" rel="stylesheet">


<!-- KaTeX排版系统 -->
<!-- KaTeX requires the use of the HTML5 doctype. Without it, KaTeX may not render properly -->
<link rel="stylesheet" href="<%- theme.cdn.katex.css %>" >
<!-- The loading of KaTeX is deferred to speed up page rendering -->
<script defer src="<%- theme.cdn.katex.js %>" ></script>

<!-- 自动渲染KaTeX扩展 -->
<!-- To automatically render math in text elements, include the auto-render extension: -->
<script defer src="<%- theme.cdn.katex.auto_render.js %>" ></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        renderMathInElement(document.body, {
          // customised options
          // • auto-render specific keys, e.g.:
          delimiters: [
              {left: '$$', right: '$$', display: true},
              {left: '$', right: '$', display: false},
              {left: '\\(', right: '\\)', display: true},
              {left: '\\[', right: '\\]', display: false}
          ],
          // • rendering keys, e.g.:
          throwOnError : true
        });
    });
</script>

<!-- 复制tex公式库 扩展 -->
<link href="<%- theme.cdn.katex.copy_tex.css %>" rel="stylesheet" type="text/css">
<script src="<%- theme.cdn.katex.copy_tex.js %>"></script>
<script>
    
</script>

<div class="nexmoe-post">

  <article>
      <% if (page.cover){ %>
          <div class="nexmoe-post-cover" style="padding-bottom: <%- page.coverHeight/page.coverWidth*100 %>%;"> 
              <img data-src="<%- page.cover %>" data-sizes="auto" alt="<%= page.title %>" class="lazyload">
              <h1><%= page.title %></h1>
          </div>
      <%}  else{ %>
          <div class="nexmoe-post-cover" style="padding-bottom: <%- theme.default_cover.height/theme.default_cover.width*100 %>%;"> 
              <img data-src="<%- theme.default_cover.path %>" data-sizes="auto" alt="<%= page.title %>" class="lazyload">
              <h1><%= page.title %></h1>
          </div>
      <% } %>
      
      <%- partial('_partial/_post/meta') %>

      

      <%- page.content %>
  </article>

  <% if (!page.reprint){ %>
      <%- partial('_partial/copyright') %>
  <% } %>
  
  <%- partial('_partial/_post/tag') %>

  <% if (page.comments){ %>
      <div class="nexmoe-post-footer">
          <%- theme.comment ? partial('_partial/comment') : '' %>
      </div>
  <% } %>
</div>