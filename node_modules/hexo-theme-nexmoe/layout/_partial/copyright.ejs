<% if (page.hide_copyright !== true && theme.copyright || page.copyright) { %>
    
    <div  class="nexmoe-post-copyright">
        <strong><%- __('copyright.author') %>：</strong><%= config.author %><br>
        <!-- <strong><%- __('copyright.permalink') %>：</strong> -->
        <!-- <%- link_to(page.permalink, page.permalink, {external: true}) %><br> -->
        <strong><%- __('copyright.permalink') %>：</strong>
        <a id="page_address_Decode" href="" title="" target="_blank" rel="noopener"></a><br>
        <strong><%- __('copyright.permalink_undecoude') %>：</strong>
        <a id="page_address_encode" href="" title="" target="_blank" rel="noopener"></a><br>
        <% if (page.copyright) { %>
            <%- page.copyright %>
        <% } else { %>
            <%- theme.copyright %>
        <% } %>
    </div>

    <script >
        setTimeout("setURL()",0 );  
        function setURL(){  
            var raw = "<%- page.permalink %>"
            var decodePageURI = decodeURI(raw)
            var encodePageURI = encodeURI(decodePageURI)
            console.log(raw);
            console.log(decodePageURI);
            console.log(encodePageURI);
            do
            {
                document.getElementById("page_address_Decode").href=decodePageURI
                document.getElementById("page_address_Decode").title=decodePageURI
                document.getElementById("page_address_Decode").innerHTML=decodePageURI
                document.getElementById("page_address_encode").href=encodePageURI
                document.getElementById("page_address_encode").title=encodePageURI
                document.getElementById("page_address_encode").innerHTML=encodePageURI
            // }while(document.getElementById("page_address_Decode").innerHTML!=decodePageURI)
            }while(document.getElementById("page_address_Decode").innerHTML!=decodePageURI)
        }  
    </script>
<% } %>


