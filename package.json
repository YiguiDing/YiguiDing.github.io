{
  "name": "yiguiding-hexo-site",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "hexo generate",
    "clean": "hexo clean",
    "deploy": "hexo deploy",
    "server": "hexo server",
    "注释1": "calendar需要git log --all获取全部分支的提交情况，所以需要fetch一下",
    "fetch": "git fetch origin",
    "calendar": "hexo gc -w=55",
    "cbs": "hexo clean && hexo gc -w=55 && hexo generate && hexo server",
    "cgd": "hexo clean && git fetch origin && hexo gc -w=55 && hexo generate && hexo deploy",
    "注释2": "json中的字符串必须是双引号，其中需要使用双引号字符需要转义（似乎还是有问题）",
    "commit": "git add . && git commit -m '更新' && git push origin master && git push origin_gitee master"
  },
  "hexo": {
    "version": "6.0.0"
  },
  "dependencies": {
    "hexo": "^6.0.0",
    "hexo-blog-encrypt": "^3.1.6",
    "hexo-calendar": "^1.0.4",
    "hexo-deployer-git": "^3.0.0",
    "hexo-generator-archive": "^1.0.0",
    "hexo-generator-category": "^1.0.0",
    "hexo-generator-index2": "^0.2.0",
    "hexo-generator-json-content": "^4.2.3",
    "hexo-generator-tag": "^1.0.0",
    "hexo-helper-live2d": "^3.1.1",
    "hexo-renderer-ejs": "^2.0.0",
    "hexo-renderer-marked": "^5.0.0",
    "hexo-renderer-stylus": "^2.0.0",
    "hexo-server": "^3.0.0",
    "hexo-tag-aplayer": "^3.0.4",
    "hexo-theme-landscape": "^0.0.3",
    "hexo-theme-nexmoe": "^3.2.7",
    "hexo-wordcount": "^6.0.1",
    "live2d-widget-model-haruto": "^1.0.5",
    "live2d-widget-model-hibiki": "^1.0.5",
    "live2d-widget-model-hijiki": "^1.0.5",
    "live2d-widget-model-izumi": "^1.0.5",
    "live2d-widget-model-koharu": "^1.0.5",
    "live2d-widget-model-shizuku": "^1.0.5",
    "live2d-widget-model-tororo": "^1.0.5",
    "live2d-widget-model-z16": "^1.0.5"
  }
}
